# Config Server
CONFIG_SERVER_PORT=8888
CONFIG_REPO_LOCATION=file:../config-repository

# XAMPP MySQL / MariaDB used by the local profile
DB_URL=jdbc:mysql://localhost:3306/order_db
DB_USERNAME=root
DB_PASSWORD=

# Local Kafka cluster
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9094,localhost:9096
ORDER_CREATED_TOPIC=order-created
ORDER_CREATED_PARTITIONS=3
ORDER_CREATED_REPLICAS=3
KAFKA_CONSUMER_GROUP=notification-service-group
KAFKA_LISTENER_CONCURRENCY=3

# Git-backed Config Server exercise
# SPRING_PROFILES_ACTIVE=git
# CONFIG_GIT_URI=https://github.com/your-user/order-platform.git
# CONFIG_GIT_DEFAULT_LABEL=main
# CONFIG_GIT_SEARCH_PATHS=config-repository
